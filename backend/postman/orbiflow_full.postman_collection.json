							"mode": "raw",
							"raw": "[\n    {\n        \"name\": \"Antigüedad\",\n        \"description\": \"Adicional automático de 1% por cada año cumplido\",\n        \"calculation_type\": \"seniority\",\n        \"applies_to_cap\": false,\n        \"is_exclusive\": true,\n        \"variants\": [\n            { \"name\": \"Valor por año\", \"type\": \"percentage\", \"value\": \"1.00\", \"is_default\": true }\n        ]\n    },\n    {\n        \"name\": \"Presentismo\",\n        \"description\": \"Bono por asistencia a la cooperativa\",\n        \"calculation_type\": \"simple\",\n        \"applies_to_cap\": true,\n        \"is_exclusive\": true,\n        \"variants\": [\n            { \"name\": \"Completo\", \"type\": \"percentage\", \"value\": \"10.00\", \"is_default\": true },\n            { \"name\": \"Medio\", \"type\": \"percentage\", \"value\": \"5.00\", \"is_default\": false }\n        ]\n    },\n    {\n        \"name\": \"Seniority\",\n        \"description\": \"Categoría según experiencia técnica\",\n        \"calculation_type\": \"simple\",\n        \"applies_to_cap\": false,\n        \"is_exclusive\": true,\n        \"variants\": [\n            { \"name\": \"Junior\", \"type\": \"percentage\", \"value\": \"2.00\", \"is_default\": true },\n            { \"name\": \"Semi-Senior\", \"type\": \"percentage\", \"value\": \"5.00\", \"is_default\": false },\n            { \"name\": \"Senior\", \"type\": \"percentage\", \"value\": \"10.00\", \"is_default\": false }\n        ]\n    },\n    {\n        \"name\": \"Formación\",\n        \"description\": \"Títulos académicos obtenidos\",\n        \"calculation_type\": \"simple\",\n        \"applies_to_cap\": false,\n        \"is_exclusive\": false,\n        \"variants\": [\n            { \"name\": \"Título de Grado\", \"type\": \"percentage\", \"value\": \"3.00\", \"is_default\": false },\n            { \"name\": \"Posgrado / MBA\", \"type\": \"percentage\", \"value\": \"5.00\", \"is_default\": false }\n        ]\n    },\n    {\n        \"name\": \"Viáticos\",\n        \"description\": \"Compensación fija por traslado\",\n        \"calculation_type\": \"simple\",\n        \"applies_to_cap\": false,\n        \"is_exclusive\": true,\n        \"variants\": [\n            { \"name\": \"Lejos de oficina\", \"type\": \"fixed_amount\", \"value\": \"5000.00\", \"is_default\": false }\n        ]\n    },\n    {\n        \"name\": \"Personas a cargo\",\n        \"description\": \"Adicional por grupo familiar\",\n        \"calculation_type\": \"simple\",\n        \"applies_to_cap\": false,\n        \"is_exclusive\": true,\n        \"variants\": [\n            { \"name\": \"1 persona\", \"type\": \"percentage\", \"value\": \"15.00\", \"is_default\": false },\n            { \"name\": \"2 personas\", \"type\": \"percentage\", \"value\": \"25.00\", \"is_default\": false },\n            { \"name\": \"3 o más personas\", \"type\": \"percentage\", \"value\": \"30.00\", \"is_default\": false }\n        ]\n    }\n]",
