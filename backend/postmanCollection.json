{
	"info": {
		"_postman_id": "orbiflow-master-coll",
		"name": "OrbiFlow",
		"description": "Colección para el sistema de gestión de cooperativas OrbiFlow.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"description": "Endpoints relacionados con la seguridad y gestión de tokens JWT.",
			"item": [
				{
					"name": "1. Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access) {",
									"    pm.environment.set(\"access_token\", response.access);",
									"    pm.environment.set(\"refresh_token\", response.refresh);",
									"    console.log(\"Tokens actualizados correctamente\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"tu_password_aca\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login/",
							"host": ["{{base_url}}"],
							"path": ["auth", "login", ""]
						}
					}
				},
				{
					"name": "2. Get My Info",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/me/",
							"host": ["{{base_url}}"],
							"path": ["auth", "me", ""]
						}
					}
				},
				{
					"name": "3. Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access) {",
									"    pm.environment.set(\"access_token\", response.access);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/refresh/",
							"host": ["{{base_url}}"],
							"path": ["auth", "refresh", ""]
						}
					}
				}
			]
		},
		{
			"name": "Asociados",
			"description": "",
			"item": []
		},
		{
			"name": "Liquidaciones",
			"description": "",
			"item": []
		}
	]
}